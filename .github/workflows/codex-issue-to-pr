name: Codex Issue → PR

on:
  issues:
    types: [opened, labeled]
  issue_comment:
    types: [created]

permissions:
  contents: write
  pull-requests: write
  issues: read

jobs:
  codex-fix:
    if: |
      (github.event_name == 'issues' && github.event.label.name == 'codex') ||
      (github.event_name == 'issues' && contains(github.event.issue.labels.*.name, 'codex')) ||
      (github.event_name == 'issue_comment' && contains(github.event.comment.body, '/codex'))
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Install Codex CLI
        run: npm install -g @openai/codex

      - name: Run Codex & Create PR
        env:
          OPENAI_API_KEY: ${{ secrets.OPENAI_API_KEY }}
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
          ISSUE_NUM: ${{ github.event.issue.number }}
          ISSUE_TITLE: ${{ github.event.issue.title }}
          ISSUE_BODY: ${{ github.event.issue.body }}
        run: |
          BRANCH="codex/issue-$ISSUE_NUM"
          git checkout -b $BRANCH
          
          codex --approval-mode full-auto \
            "GitHub Issue #$ISSUE_NUM — $ISSUE_TITLE
            
            $ISSUE_BODY
            
            Please understand this issue, find relevant code, implement the fix, and stop. Do NOT commit — I will handle git."
          
          git add -A
          git diff --cached --quiet || {
            git config user.name "Codex Bot"
            git config user.email "codex-bot@noreply.github.com"
            git commit -m "fix: $ISSUE_TITLE (closes #$ISSUE_NUM)"
            git push -u origin $BRANCH
            gh pr create \
              --title "fix: $ISSUE_TITLE" \
              --body "Closes #$ISSUE_NUM — auto-generated by Codex" \
              --head $BRANCH \
              --base main
            gh issue comment $ISSUE_NUM --body "✅ Codex opened a PR for this issue."
          }
